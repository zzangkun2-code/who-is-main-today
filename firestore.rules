rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isValidRoomNumber(roomNumber) {
      return roomNumber is string && roomNumber.matches('^[0-9]{1,12}$');
    }

    function isRoomPayload(roomNumber) {
      return request.resource.data.keys().hasOnly([
          'roomNumber',
          'password',
          'passwordHash',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.roomNumber == roomNumber
        && isValidRoomNumber(request.resource.data.roomNumber)
        && request.resource.data.updatedAt is string;
    }

    function isMemberPayload(roomNumber, memberId) {
      return request.resource.data.keys().hasOnly([
          'id',
          'roomNumber',
          'name',
          'gender',
          'birthDate',
          'birthTime',
          'avatarId',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.id == memberId
        && request.resource.data.roomNumber == roomNumber
        && request.resource.data.name is string
        && request.resource.data.gender in ['female', 'male']
        && request.resource.data.birthDate is string
        && request.resource.data.birthTime is string
        && request.resource.data.avatarId is string
        && request.resource.data.updatedAt is string;
    }

    match /groupRooms/{roomNumber} {
      allow read: if isValidRoomNumber(roomNumber);
      allow create: if isRoomPayload(roomNumber);
      allow update: if isRoomPayload(roomNumber);

      // Prototype admin mode can delete rooms from the client.
      // For production, move admin deletion behind Firebase Auth or a server API.
      allow delete: if isValidRoomNumber(roomNumber);

      match /members/{memberId} {
        allow read: if isValidRoomNumber(roomNumber);
        allow create: if isMemberPayload(roomNumber, memberId);
        allow update: if isMemberPayload(roomNumber, memberId);

        // Prototype admin/member deletion is client-side.
        // For production, protect this with Firebase Auth or a server API.
        allow delete: if isValidRoomNumber(roomNumber);
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
